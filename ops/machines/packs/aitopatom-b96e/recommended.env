# aitopatom-b96e — 建議環境變數（無密鑰）
# 用法：在 repo 根執行
#   set -a && source ops/machines/packs/aitopatom-b96e/recommended.env && set +a
#
# 僅供 hostname=aitopatom-b96e。對立機請用 packs/DESKTOP-8MQPFS8/。

# --- 本機身分（說明用；setup_check.sh 會核對 hostname）---
AUGUR_MACHINE_HOST=aitopatom-b96e
AUGUR_MACHINE_ROLE=governance+local-inference

# --- 路徑（此機實際佈局）---
# 憲章／工具 repo 根（Cursor workspace）
AUGUR_CONSTITUTION_ROOT=/home/giga/augur
# 應用碼工作副本（正典認定仍待 Steward）
AUGUR_CODE=/home/giga/augur-code-work

# --- Ollama / 嵌入（MCP 與 CLI 共用）---
OLLAMA_URL=http://127.0.0.1:11434
# 可不設：local_llm_mcp 對此 hostname 預設 qwen3:30b-a3b
# OLLAMA_MODEL=qwen3:30b-a3b
EMBED_MODEL=nomic-embed-text

# --- project-memory（索引為本機衍生物，不進 git）---
# MEMORY_DB 預設 = $AUGUR_CONSTITUTION_ROOT/.project_memory/index.db
