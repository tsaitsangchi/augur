# aitopatom-b96e — 建議環境變數（無密鑰）
# 用法：在 repo 根執行
#   set -a && source ops/machines/packs/aitopatom-b96e/recommended.env && set +a
#
# 僅供 hostname=aitopatom-b96e。對立機請用 packs/DESKTOP-8MQPFS8/。

# --- 本機身分（說明用；setup_check.sh 會核對 hostname）---
AUGUR_MACHINE_HOST=aitopatom-b96e
AUGUR_MACHINE_ROLE=fullstack-T1

# --- 路徑（終態：單一 monorepo 根）---
# 過渡期若仍在 /home/giga/augur-code-work 開發，可暫時覆寫為該路徑。
AUGUR_ROOT=/home/giga/augur
PROJECT_ROOT=/home/giga/augur
# 過渡別名（合倉後與 AUGUR_ROOT 同義；新腳本請用 AUGUR_ROOT／PROJECT_ROOT）
AUGUR_CONSTITUTION_ROOT=/home/giga/augur
AUGUR_CODE=/home/giga/augur

# --- Ollama / 嵌入（MCP 與 CLI 共用）---
OLLAMA_URL=http://127.0.0.1:11434
# 倉庫 .mcp.json 釘 LLM_MODEL=qwen3:4b（WSL 預設）——GB10 必須覆寫 LLM_MODEL，勿只改 OLLAMA_MODEL
LLM_MODEL=qwen3-coder-next
OLLAMA_MODEL=qwen3-coder-next
OLLAMA_NUM_CTX=32768
OLLAMA_KEEP_ALIVE=30m
EMBED_MODEL=nomic-embed-text

# --- 可選：local-llm MCP → vLLM（OpenAI 相容）---
# 倉庫預設改走：reports/local_llm_vllm_default_plan_20260722.md（待拍板）
# 最佳化／階梯：reports/local_llm_vllm_optimization_plan_20260722.md
# project-memory embed 維持 Ollama。見 ops/phase2/VLLM-GB10.md
# 並存：起 vLLM 前 ollama stop qwen3:30b-a3b（保留 nomic-embed-text）
# LLM_BACKEND=openai
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=EMPTY
# LLM_MODEL=qwen3-4b
# （L0 煙霧：qwen3-0.6b；須與 vllm --served-model-name 對齊；venv 需 ninja）
# OPENAI_MAX_TOKENS=1024
# OPENAI_MAX_TOKENS_ASK=256
# OPENAI_MAX_TOKENS_SUMMARIZE=512
# OLLAMA_TEMPERATURE=0.2

# --- project-memory（索引為本機衍生物，不進 git）---
# MEMORY_DB 預設 = $AUGUR_ROOT/.project_memory/index.db
