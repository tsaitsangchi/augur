[Unit]
Description=augur probability UI (:8600)
After=network-online.target augur-postgres.service
Wants=augur-postgres.service

[Service]
Type=simple
WorkingDirectory=/home/giga/augur
EnvironmentFile=/home/giga/augur/.env
ExecStart=/home/giga/augur/venv/bin/python /home/giga/augur/scripts/serve_probability_ui.py --serve
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
